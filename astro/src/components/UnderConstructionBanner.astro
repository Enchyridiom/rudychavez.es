---
const TEXT_SHORT = 'Sitio en construcción';
const TEXT_FULL = 'Sitio en construcción — algunas secciones están en desarrollo';
---

<div
  data-uc-banner
  class="fixed top-0 left-0 right-0 z-[100] flex items-center justify-center h-[2.5rem] px-12 bg-[#2f333e] text-[#f7f3e8] text-xs md:text-sm whitespace-nowrap overflow-hidden hidden"
  style="transform: translateY(-100%); font-feature-settings: 'ss03' 1;"
>
  <span data-uc-short class="md:hidden">{TEXT_SHORT}</span>
  <span data-uc-full class="hidden md:inline">{TEXT_FULL}</span>
  <button
    data-uc-close
    class="absolute right-4 top-1/2 -translate-y-1/2 text-[#f7f3e8] hover:text-[#76e384] transition-colors cursor-pointer opacity-0"
    aria-label="Cerrar aviso"
  >
    ✕
  </button>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';

  gsap.registerPlugin(ScrambleTextPlugin);

  const STORAGE_KEY = 'uc-banner-dismissed';
  const TEXT_SHORT = 'Sitio en construcción';
  const TEXT_FULL = 'Sitio en construcción — algunas secciones están en desarrollo';

  const banner = document.querySelector<HTMLDivElement>('[data-uc-banner]');
  const shortEl = document.querySelector<HTMLSpanElement>('[data-uc-short]');
  const fullEl = document.querySelector<HTMLSpanElement>('[data-uc-full]');
  const closeEl = document.querySelector<HTMLButtonElement>('[data-uc-close]');

  if (banner && shortEl && fullEl && closeEl) {
    if (sessionStorage.getItem(STORAGE_KEY)) {
      banner.remove();
    } else {
      banner.classList.remove('hidden');

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        gsap.set(banner, { y: '0%' });
        shortEl.textContent = TEXT_SHORT;
        fullEl.textContent = TEXT_FULL;
        gsap.set(closeEl, { opacity: 1 });
      } else {
        shortEl.textContent = '';
        fullEl.textContent = '';

        const tl = gsap.timeline();
        tl.fromTo(
          banner,
          { y: '-100%' },
          { y: '0%', duration: 0.6, ease: 'power4.out' },
          0
        )
          .to(
            shortEl,
            {
              duration: 0.8,
              scrambleText: {
                text: TEXT_SHORT,
                chars: 'lowerCase',
                speed: 0.7,
                revealDelay: 0.1,
              },
              ease: 'power4.out',
            },
            '-=0.35'
          )
          .to(
            fullEl,
            {
              duration: 0.8,
              scrambleText: {
                text: TEXT_FULL,
                chars: 'lowerCase',
                speed: 0.7,
                revealDelay: 0.1,
              },
              ease: 'power4.out',
            },
            '<'
          )
          .to(
            closeEl,
            { opacity: 1, duration: 0.35, ease: 'power2.out' },
            '-=0.4'
          );
      }

      closeEl.addEventListener('click', () => {
        gsap.to(banner, {
          y: '-100%',
          duration: 0.35,
          ease: 'power3.in',
          onComplete: () => {
            sessionStorage.setItem(STORAGE_KEY, '1');
            banner.remove();
          },
        });
      });
    }
  }
</script>
