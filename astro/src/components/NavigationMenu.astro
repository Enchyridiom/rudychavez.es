---
// NavigationMenu.astro — variante up-down (única usada en páginas internas)
//
// Migración del original Next.js que usaba GSAP timeline para el morph.
// Aquí el morph pastilla→overlay se hace con View Transitions API:
// pill y overlay comparten `view-transition-name: nav-morph`, y al hacer
// `display: none` en uno + visible el otro dentro de `startViewTransition`,
// el navegador interpola posición, tamaño y border-radius nativamente.
//
// Coste: ~0kB de JS de animación (solo la API nativa). El resto es CSS.
//
// TODOs futuros si se necesitan:
//   - Variantes back-forward y full
//   - Stagger animado de los enlaces del overlay al entrar
//   - tone='footer' aún no usado (subpáginas siempre default)

interface Props {
  tone?: 'default' | 'footer';
}

const { tone = 'default' } = Astro.props;

const arrowClass =
  tone === 'footer'
    ? 'bg-[#f7f3e8] text-[#d42b57] hover:bg-[#2f333e] hover:text-[#f7f3e8] focus-visible:ring-[#2f333e]'
    : 'bg-[#d42b57] text-[#f7f3e8] hover:bg-[#5576e8] focus-visible:ring-[#5576e8]';

const pillClass =
  tone === 'footer'
    ? 'bg-[#f7f3e8] text-[#d42b57] hover:bg-[#2f333e] hover:text-[#f7f3e8] focus-visible:ring-[#2f333e]'
    : 'bg-[#d42b57] text-[#f7f3e8] hover:bg-[#5576e8] focus-visible:ring-[#5576e8]';
---

<!-- Backdrop con blur, oculto por defecto -->
<div
  data-nav-backdrop
  class="fixed inset-0 z-40 bg-[#f7f3e8]/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<!-- Bottom nav bar: arrow up + pill + arrow down -->
<div class="fixed inset-x-0 bottom-6 z-50 flex justify-center">
  <div class="flex gap-3 items-center">
    <button
      data-nav-up
      type="button"
      aria-label="Ir arriba"
      class:list={[
        'w-12 h-12 rounded-full flex items-center justify-center select-none transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2',
        arrowClass,
      ]}
    >
      <span class="text-xl leading-none">↑</span>
    </button>

    <button
      data-nav-pill
      type="button"
      aria-label="Abrir menú"
      class:list={[
        'h-12 px-6 rounded-full flex items-center justify-center select-none transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2',
        pillClass,
      ]}
      style="view-transition-name: nav-morph;"
    >
      <span class="text-base">Menu</span>
    </button>

    <button
      data-nav-down
      type="button"
      aria-label="Ir abajo"
      class:list={[
        'w-12 h-12 rounded-full flex items-center justify-center select-none transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2',
        arrowClass,
      ]}
    >
      <span class="text-xl leading-none">↓</span>
    </button>
  </div>
</div>

<!-- Overlay: 80vw × 70dvh centrado. display:none por defecto.
     Comparte view-transition-name con la pastilla: el navegador
     interpola entre ambos cuando se hace startViewTransition. -->
<div
  data-nav-overlay
  class="fixed top-[15dvh] left-[10vw] w-[80vw] h-[70dvh] z-50 bg-[#d42b57] text-[#f7f3e8] rounded-3xl flex-col items-center justify-center hidden"
  style="view-transition-name: nav-morph;"
>
  <div class="w-full h-full flex flex-col items-center justify-center px-8">
    <nav class="flex flex-col items-center gap-8">
      <a href="/" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Home</a>
      <a href="/projects" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Proyectos</a>
      <a href="/about" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">About</a>
      <a href="/contact" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Contacto</a>
    </nav>

    <button
      data-nav-close
      type="button"
      aria-label="Cerrar menú"
      class="mt-24 h-12 px-5 rounded-full bg-[#f7f3e8] text-[#d42b57] flex items-center justify-center select-none transition-colors duration-150 hover:bg-[#2f333e] hover:text-[#f7f3e8] active:bg-[#2f333e] active:text-[#f7f3e8] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2f333e]"
    >
      <span class="text-base">Cerrar</span>
    </button>
  </div>
</div>

<script>
  const pill = document.querySelector<HTMLButtonElement>('[data-nav-pill]');
  const overlay = document.querySelector<HTMLDivElement>('[data-nav-overlay]');
  const backdrop = document.querySelector<HTMLDivElement>('[data-nav-backdrop]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-nav-close]');
  const upBtn = document.querySelector<HTMLButtonElement>('[data-nav-up]');
  const downBtn = document.querySelector<HTMLButtonElement>('[data-nav-down]');

  if (pill && overlay && backdrop && closeBtn && upBtn && downBtn) {
    let menuOpen = false;
    const pillLabel = pill.querySelector<HTMLSpanElement>('span');

    const applyState = () => {
      if (menuOpen) {
        pill.classList.add('hidden');
        overlay.classList.remove('hidden');
        overlay.classList.add('flex', 'animate-stagger');
        backdrop.style.opacity = '1';
        backdrop.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
      } else {
        pill.classList.remove('hidden');
        overlay.classList.add('hidden');
        overlay.classList.remove('flex', 'animate-stagger');
        backdrop.style.opacity = '0';
        backdrop.style.pointerEvents = 'none';
        document.body.style.overflow = '';
        // Restaurar el texto "Menu" para el siguiente snapshot/render
        if (pillLabel) pillLabel.style.opacity = '';
      }
    };

    const toggle = () => {
      const willOpen = !menuOpen;

      // Al ABRIR: ocultar el texto "Menu" ANTES de capturar el snapshot.
      // El snapshot OLD se escala junto al contenedor durante el morph;
      // si la pastilla no tiene texto al ser capturada, no hay nada que
      // se vea creciendo. La pastilla mantiene su anchura porque el span
      // sigue ocupando espacio (opacity 0, no display:none).
      if (willOpen && pillLabel) {
        pillLabel.style.opacity = '0';
      }

      menuOpen = willOpen;

      // View Transitions API: si el navegador la soporta, encapsulamos el
      // cambio de DOM dentro de startViewTransition para que interpole
      // posición/tamaño/border-radius de pill ↔ overlay automáticamente.
      const doc = document as Document & {
        startViewTransition?: (cb: () => void) => unknown;
      };

      if (doc.startViewTransition) {
        doc.startViewTransition(applyState);
      } else {
        // Fallback (Firefox sin VT, navegadores antiguos): toggle instantáneo
        applyState();
      }
    };

    pill.addEventListener('click', toggle);
    closeBtn.addEventListener('click', toggle);
    backdrop.addEventListener('click', toggle);

    // Cierra el menú con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) toggle();
    });

    upBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    downBtn.addEventListener('click', () => {
      window.scrollTo({
        top: document.body.scrollHeight,
        behavior: 'smooth',
      });
    });
  }
</script>

<style>
  /* Morph del contenedor: 0.95s easeInQuad (lento al inicio, acelera al final). */
  ::view-transition-group(nav-morph) {
    animation-duration: 0.85s;
    animation-timing-function: cubic-bezier(0.55, 0.085, 0.68, 0.53);
  }

  /* Snapshot del estado anterior (pill al abrir, overlay al cerrar):
     fade-out rápido para que el texto "Menu" o los links no se vean
     escalándose junto al contenedor durante el morph. */
  ::view-transition-old(nav-morph) {
    animation-duration: 0.6s;
    animation-timing-function: ease-out;
  }

  /* Snapshot del estado nuevo: fade-in sincronizado con el morph. */
  ::view-transition-new(nav-morph) {
    animation-duration: 0.85s;
    animation-timing-function: cubic-bezier(0.55, 0.085, 0.68, 0.53);
  }

  /* Stagger de los enlaces del overlay.
     Estado inicial: invisibles + ligeramente desplazados.
     Cuando se aplica .animate-stagger, cada enlace anima con delay
     escalonado que arranca a 0.7s (ligeramente antes de que el morph
     acabe a 0.95s) para encadenar sin pausa. */
  [data-nav-overlay] nav a,
  [data-nav-overlay] [data-nav-close] {
    opacity: 0;
    transform: translateY(20px);
  }

  [data-nav-overlay].animate-stagger nav a,
  [data-nav-overlay].animate-stagger [data-nav-close] {
    animation: menu-item-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  [data-nav-overlay].animate-stagger nav a:nth-child(1) { animation-delay: 0.25s; }
  [data-nav-overlay].animate-stagger nav a:nth-child(2) { animation-delay: 0.33s; }
  [data-nav-overlay].animate-stagger nav a:nth-child(3) { animation-delay: 0.41s; }
  [data-nav-overlay].animate-stagger nav a:nth-child(4) { animation-delay: 0.49s; }
  [data-nav-overlay].animate-stagger [data-nav-close]   { animation-delay: 0.60s; }

  @keyframes menu-item-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
