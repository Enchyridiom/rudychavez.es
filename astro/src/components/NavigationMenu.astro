---
// NavigationMenu.astro — variante up-down (única usada en páginas internas)
//
// Migración del original Next.js + GSAP. El morph se hace ahora con
// CSS transitions sobre un único elemento vivo (data-nav-morph):
//
//   1. JS lee la posición real de la pastilla con getBoundingClientRect()
//   2. Posiciona el morph-box exactamente sobre la pastilla, sin transición
//   3. Fuerza un reflow y restaura la transición CSS
//   4. Cambia los estilos a la geometría del overlay
//   5. El navegador interpola width/height/left/top/border-radius continuamente
//
// Mismo planteamiento del original (animar propiedades CSS reales sobre un
// elemento vivo) pero sin GSAP. Coste: ~50 líneas de JS, 0kB de librería.
//
// TODOs futuros si se necesitan:
//   - Variantes back-forward y full
//   - tone='footer' aún no usado (subpáginas siempre default)

interface Props {
  tone?: 'default' | 'footer';
}

const { tone = 'default' } = Astro.props;

const arrowClass =
  tone === 'footer'
    ? 'bg-[#f7f3e8] text-[#d42b57] hover:bg-[#2f333e] hover:text-[#f7f3e8] focus-visible:ring-[#2f333e]'
    : 'bg-[#d42b57] text-[#f7f3e8] hover:bg-[#5576e8] focus-visible:ring-[#5576e8]';

const pillClass =
  tone === 'footer'
    ? 'bg-[#f7f3e8] text-[#d42b57] hover:bg-[#2f333e] hover:text-[#f7f3e8] focus-visible:ring-[#2f333e]'
    : 'bg-[#d42b57] text-[#f7f3e8] hover:bg-[#5576e8] focus-visible:ring-[#5576e8]';
---

<!-- Backdrop -->
<div
  data-nav-backdrop
  class="fixed inset-0 z-40 bg-[#f7f3e8]/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<!-- Bottom nav bar: arrow up + pill + arrow down -->
<div class="fixed inset-x-0 bottom-6 z-50 flex justify-center">
  <div class="flex gap-3 items-center">
    <button
      data-nav-up
      type="button"
      aria-label="Ir arriba"
      class:list={[
        'w-12 h-12 rounded-full flex items-center justify-center select-none transition duration-150 focus-visible:outline-none focus-visible:ring-2',
        arrowClass,
      ]}
    >
      <span class="text-xl leading-none">↑</span>
    </button>

    <button
      data-nav-pill
      type="button"
      aria-label="Abrir menú"
      class:list={[
        'h-12 px-6 rounded-full flex items-center justify-center select-none transition duration-150 focus-visible:outline-none focus-visible:ring-2',
        pillClass,
      ]}
    >
      <span class="text-base">Menu</span>
    </button>

    <button
      data-nav-down
      type="button"
      aria-label="Ir abajo"
      class:list={[
        'w-12 h-12 rounded-full flex items-center justify-center select-none transition duration-150 focus-visible:outline-none focus-visible:ring-2',
        arrowClass,
      ]}
    >
      <span class="text-xl leading-none">↓</span>
    </button>
  </div>
</div>

<!-- Morph-box: el único elemento que viaja. display:none hasta abrir.
     JS lo posiciona inline (left/top/width/height/border-radius) en
     dos pasos: primero igualando la pastilla, luego al overlay final.
     CSS transition interpola entre ambos estados. -->
<div
  data-nav-morph
  class="fixed z-50 bg-[#d42b57] text-[#f7f3e8] flex-col items-center justify-center hidden overflow-hidden"
>
  <div class="w-full h-full flex flex-col items-center justify-center px-8">
    <nav class="flex flex-col items-center gap-8">
      <a href="/" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Home</a>
      <a href="/projects" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Proyectos</a>
      <a href="/about" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">About</a>
      <a href="/contact" class="text-4xl no-underline hover:text-[#2f333e] active:text-[#2f333e]">Contacto</a>
    </nav>

    <button
      data-nav-close
      type="button"
      aria-label="Cerrar menú"
      class="mt-24 h-12 px-5 rounded-full bg-[#f7f3e8] text-[#d42b57] flex items-center justify-center select-none transition-colors duration-150 hover:bg-[#2f333e] hover:text-[#f7f3e8] active:bg-[#2f333e] active:text-[#f7f3e8] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2f333e]"
    >
      <span class="text-base">Cerrar</span>
    </button>
  </div>
</div>

<script>
  const pill = document.querySelector<HTMLButtonElement>('[data-nav-pill]');
  const morph = document.querySelector<HTMLDivElement>('[data-nav-morph]');
  const backdrop = document.querySelector<HTMLDivElement>('[data-nav-backdrop]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-nav-close]');
  const upBtn = document.querySelector<HTMLButtonElement>('[data-nav-up]');
  const downBtn = document.querySelector<HTMLButtonElement>('[data-nav-down]');

  if (pill && morph && backdrop && closeBtn && upBtn && downBtn) {
    // Mantener este valor sincronizado con --nav-morph-duration en el CSS
    const TRANSITION_MS = 300;

    let menuOpen = false;
    let isAnimating = false;

    // Aplica al morph-box los estilos de la pastilla (geometría inicial).
    // No transiciona si la propiedad inline `transition` está en 'none'.
    const setPillState = () => {
      const rect = pill.getBoundingClientRect();
      morph.style.left = `${rect.left}px`;
      morph.style.top = `${rect.top}px`;
      morph.style.width = `${rect.width}px`;
      morph.style.height = `${rect.height}px`;
      morph.style.borderRadius = '9999px';
    };

    // Aplica los estilos del overlay (geometría final, 80vw × 70dvh centrado).
    const setOverlayState = () => {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const w = Math.round(vw * 0.8);
      const h = Math.round(vh * 0.7);
      morph.style.left = `${Math.round((vw - w) / 2)}px`;
      morph.style.top = `${Math.round((vh - h) / 2)}px`;
      morph.style.width = `${w}px`;
      morph.style.height = `${h}px`;
      morph.style.borderRadius = '24px';
    };

    const open = () => {
      if (isAnimating) return;
      isAnimating = true;
      menuOpen = true;

      // 1. Hacer visible el morph-box sin transición y posicionarlo
      //    EXACTAMENTE sobre la pastilla.
      morph.style.transition = 'none';
      morph.classList.remove('hidden');
      morph.classList.add('flex');
      setPillState();

      // 2. Ocultar la pastilla (instantáneo).
      pill.style.opacity = '0';
      pill.style.pointerEvents = 'none';

      // 3. Forzar reflow para que los estilos anteriores se "asienten"
      //    como estado inicial antes de que cambiemos al final.
      void morph.offsetWidth;

      // 4. Restaurar la transición CSS y animar a la geometría del overlay.
      morph.style.transition = '';
      setOverlayState();

      // 5. Backdrop visible y body lock.
      backdrop.style.opacity = '1';
      backdrop.style.pointerEvents = 'auto';
      document.body.style.overflow = 'hidden';

      // 6. Disparar el stagger del contenido (los items entran con
      //    delays definidos en CSS para alinearse con el morph).
      morph.classList.add('animate-stagger');

      // 7. Liberar el flag al finalizar la transición.
      window.setTimeout(() => {
        isAnimating = false;
      }, TRANSITION_MS);
    };

    const close = () => {
      if (isAnimating) return;
      isAnimating = true;
      menuOpen = false;

      // 1. Quitar el stagger → los items se desvanecen vía la transition
      //    que tienen definida en CSS (rápida, ~0.25s).
      morph.classList.remove('animate-stagger');

      // 2. Animar el morph-box de vuelta a la geometría de la pastilla.
      setPillState();

      // 3. Backdrop fuera y restaurar scroll.
      backdrop.style.opacity = '0';
      backdrop.style.pointerEvents = 'none';
      document.body.style.overflow = '';

      // 4. Al terminar la transición: ocultar el morph-box y restaurar
      //    la pastilla original a opacidad plena.
      window.setTimeout(() => {
        morph.classList.add('hidden');
        morph.classList.remove('flex');
        pill.style.opacity = '';
        pill.style.pointerEvents = '';
        isAnimating = false;
      }, TRANSITION_MS);
    };

    const toggle = () => {
      if (menuOpen) close();
      else open();
    };

    pill.addEventListener('click', toggle);
    closeBtn.addEventListener('click', toggle);
    backdrop.addEventListener('click', toggle);

    // Cierra el menú con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) toggle();
    });

    upBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    downBtn.addEventListener('click', () => {
      window.scrollTo({
        top: document.body.scrollHeight,
        behavior: 'smooth',
      });
    });
  }
</script>

<style>
  /* Morph genuino: el elemento se anima a sí mismo entre la geometría
     de la pastilla y la del overlay. CSS transition interpola width,
     height, left, top y border-radius CONTINUAMENTE sobre el mismo
     elemento — exactamente lo que hacía el original con GSAP. */
  [data-nav-morph] {
    transition-property: width, height, left, top, border-radius;
    transition-duration: 0.3s;
    transition-timing-function: cubic-bezier(0.45, 0.14, 0.7, 0.34);
  }

  /* Estado inicial de los enlaces y del botón cerrar: invisibles y
     ligeramente desplazados. Tienen además su propia transition para
     desvanecerse rápido al cerrar (cuando se quita .animate-stagger). */
  [data-nav-morph] nav a,
  [data-nav-morph] [data-nav-close] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.15s ease-out, transform 0.15s ease-out;
  }

  /* Stagger al abrir: cada item entra con un delay creciente. Los
     delays empiezan a 0.55s para que lleguen al final del morph
     (0.85s) ya en mid-animación, encadenando sin pausa. */
  [data-nav-morph].animate-stagger nav a,
  [data-nav-morph].animate-stagger [data-nav-close] {
    animation: menu-item-in 0.28s cubic-bezier(0.45, 0.14, 0.7, 0.34) forwards;
  }

  [data-nav-morph].animate-stagger nav a:nth-child(1) { animation-delay: 0.08s; }
  [data-nav-morph].animate-stagger nav a:nth-child(2) { animation-delay: 0.12s; }
  [data-nav-morph].animate-stagger nav a:nth-child(3) { animation-delay: 0.16s; }
  [data-nav-morph].animate-stagger nav a:nth-child(4) { animation-delay: 0.2s; }
  [data-nav-morph].animate-stagger [data-nav-close]   { animation-delay: 0.24s; }

  @keyframes menu-item-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
